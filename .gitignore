# Dependencies
node_modules/

# Build output
# NOTE: during the pre-release phase dist/ is COMMITTED so the package can be
# consumed as a git dependency (github:valianx/resilient-pubsub#sha) without a
# rebuild on the consumer — the tsup DTS rollup is flaky in the Linux git-prepare
# sandbox (CI), even though it builds fine locally and in this repo's own CI.
# Only sourcemaps are ignored to keep the tree lean. At npm-publish this is
# reverted: dist/ goes back to fully ignored and prepublishOnly rebuilds it.
dist/*.map
dist/**/*.map

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
coverage/

# Package manager locks
# pnpm-lock.yaml is committed (do not ignore)
# package-lock.json and bun.lockb are not used
package-lock.json
bun.lockb

# Temporary files
*.tmp
*.temp
.cache/

# Claude Code session docs
/workspaces/
