{
  "name": "resilient-pubsub",
  "version": "0.0.0",
  "description": "A transparent, framework-agnostic resilience layer around @google-cloud/pubsub: idempotency, structured envelopes, retries with backoff/jitter, native dead-letter support.",
  "packageManager": "pnpm@11.1.3",
  "author": "valianx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valianx/resilient-pubsub.git"
  },
  "bugs": {
    "url": "https://github.com/valianx/resilient-pubsub/issues"
  },
  "homepage": "https://github.com/valianx/resilient-pubsub#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./publisher": {
      "import": {
        "types": "./dist/publisher/index.d.ts",
        "default": "./dist/publisher/index.js"
      },
      "require": {
        "types": "./dist/publisher/index.d.cts",
        "default": "./dist/publisher/index.cjs"
      }
    },
    "./subscriber": {
      "import": {
        "types": "./dist/subscriber/index.d.ts",
        "default": "./dist/subscriber/index.js"
      },
      "require": {
        "types": "./dist/subscriber/index.d.cts",
        "default": "./dist/subscriber/index.cjs"
      }
    },
    "./idempotency": {
      "import": {
        "types": "./dist/idempotency/index.d.ts",
        "default": "./dist/idempotency/index.js"
      },
      "require": {
        "types": "./dist/idempotency/index.d.cts",
        "default": "./dist/idempotency/index.cjs"
      }
    },
    "./idempotency/redis": {
      "import": {
        "types": "./dist/idempotency/redis.d.ts",
        "default": "./dist/idempotency/redis.js"
      },
      "require": {
        "types": "./dist/idempotency/redis.d.cts",
        "default": "./dist/idempotency/redis.cjs"
      }
    },
    "./dlq": {
      "import": {
        "types": "./dist/dlq/index.d.ts",
        "default": "./dist/dlq/index.js"
      },
      "require": {
        "types": "./dist/dlq/index.d.cts",
        "default": "./dist/dlq/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./envelope": {
      "import": {
        "types": "./dist/envelope/index.d.ts",
        "default": "./dist/envelope/index.js"
      },
      "require": {
        "types": "./dist/envelope/index.d.cts",
        "default": "./dist/envelope/index.cjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors/index.d.ts",
        "default": "./dist/errors/index.js"
      },
      "require": {
        "types": "./dist/errors/index.d.cts",
        "default": "./dist/errors/index.cjs"
      }
    },
    "./propagation": {
      "import": {
        "types": "./dist/propagation/index.d.ts",
        "default": "./dist/propagation/index.js"
      },
      "require": {
        "types": "./dist/propagation/index.d.cts",
        "default": "./dist/propagation/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "test:node": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@google-cloud/pubsub": ">=5 <6",
    "redis": ">=4 <7"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "bun-types": "^1.0.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "redis": "^6.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "pubsub",
    "google-cloud-pubsub",
    "resilience",
    "retry",
    "backoff",
    "jitter",
    "idempotency",
    "dead-letter",
    "envelope",
    "typescript",
    "nodejs",
    "fault-tolerance",
    "message-queue"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9"
  }
}
